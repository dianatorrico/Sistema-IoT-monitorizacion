<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- ================= HEADER ================= -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="406dp"
        android:layout_height="119dp"
        android:background="@drawable/bg_header_gradient"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/streetname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dispositivo: -"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Estado del dispositivo en tiempo real"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvConexion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="❌ Dispositivo no conectado"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/streetname" />

    </LinearLayout>

    <!-- ================= CONTENIDO ================= -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/actionsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- Instante -->
            <TextView
                android:id="@+id/tvRtInstante"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Instante: -"
                android:textColor="?attr/colorOnPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingVertical="10dp"
                android:paddingHorizontal="18dp"
                android:background="@drawable/bg_chip_blue"
                android:layout_marginBottom="24dp"/>

            <!-- ===== GRID TARJETAS ===== -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="true">

                <!-- Luz -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Iluminación"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnBackground"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tvRtLuz"
                            android:text="Luz ambiente: -"
                            android:textSize="15sp"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginTop="6dp"/>
                        <TextView
                            android:id="@+id/tvLuzEmoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="☀️"
                            android:textSize="24sp"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Mensaje -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    >


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mensaje"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnBackground"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tvRtMensaje"
                            android:text="Mensaje: -"
                            android:textSize="15sp"
                            android:maxLines="3"
                            android:layout_marginTop="8dp"
                            android:textColor="?attr/colorOnSurface"
                            />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CO2 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CO₂"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnBackground"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tvRtCo2"
                            android:text="CO₂: -"
                            android:textSize="15sp"
                            android:layout_marginTop="8dp"
                            android:textColor="?attr/colorOnSurface"
                            />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Calidad -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calidad del aire"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnBackground"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tvRtCalidadAire"
                            android:text="Calidad del aire: -"
                            android:textSize="15sp"
                            android:layout_marginTop="8dp"
                            android:textColor="?attr/colorOnSurface"
                            />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ================= ACCIONES ================= -->
    <LinearLayout
        android:id="@+id/actionsContainer"
        android:layout_width="406dp"
        android:layout_height="198dp"
        android:background="?attr/colorSurface"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.6"
        app:layout_constraintStart_toStartOf="parent"
        >

        <TextView
            android:id="@+id/tvHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:text="¿Quieres ver información pasada?"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            />

        <Button
            android:id="@+id/btnFecha"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="?attr/colorPrimary"
            android:text="FECHA"
            android:textColor="?attr/colorOnPrimary"
            />

        <Button
            android:id="@+id/btnHoraInicio"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="?attr/colorPrimary"
            android:text="FECHA Y HORA"
            android:textColor="?attr/colorOnPrimary"
            />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
