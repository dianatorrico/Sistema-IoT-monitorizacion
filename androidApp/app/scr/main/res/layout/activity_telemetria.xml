<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Telemetria">

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Datos del dispositivo"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- FECHA SELECCIONADA -->
    <TextView
        android:id="@+id/tvFecha"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Fecha: YYYY-MM-DD"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CABECERA DE TABLA (como en la web) -->
    <!-- CABECERA DE TABLA (adaptada a móvil) -->
    <LinearLayout
        android:id="@+id/headerTabla"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E3F2FD"
        android:paddingVertical="6dp"
        android:paddingHorizontal="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvFecha"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HORA -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Hora"
            android:textStyle="bold"
            android:textSize="12sp"
            android:maxLines="1"/>

        <!-- MENSAJE -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:text="Mensaje"
            android:textStyle="bold"
            android:textSize="12sp"
            android:maxLines="1"/>

        <!-- CO2 -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:text="CO₂"
            android:textStyle="bold"
            android:textSize="12sp"
            android:gravity="end"
            android:maxLines="1"/>

        <!-- LUZ -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="Luz"
            android:textStyle="bold"
            android:textSize="12sp"
            android:gravity="center"
            android:maxLines="1"/>

        <!-- CALIDAD AIRE -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Calidad"
            android:textStyle="bold"
            android:textSize="12sp"
            android:gravity="center"
            android:maxLines="1"/>
    </LinearLayout>

    <!-- ZONA DE RESULTADOS -->
    <!-- De momento ScrollView + LinearLayout (luego RecyclerView) -->
    <ScrollView
        android:id="@+id/scrollResultados"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerTabla"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/contenedorResultados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- AQUÍ SE AÑADEN FILAS DINÁMICAMENTE DESDE JAVA -->
            <!-- Cada fila representará una Telemetria -->

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
